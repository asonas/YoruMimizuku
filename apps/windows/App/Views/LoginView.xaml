<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="YoruMimizuku.App.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:web="using:Microsoft.UI.Xaml.Controls">

    <Grid>
        <!-- Handle entry -->
        <StackPanel x:Name="EntryPanel" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="12" Width="360">
            <TextBlock Text="YoruMimizuku" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />
            <TextBlock Text="Bluesky のハンドルでサインイン" Opacity="0.7" HorizontalAlignment="Center" />
            <TextBox x:Name="HandleBox" PlaceholderText="you.bsky.social" />
            <Button x:Name="SignInButton" Content="サインイン" HorizontalAlignment="Stretch" Click="OnSignInClick" />
            <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed" />
            <ProgressRing x:Name="Spinner" IsActive="False" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- OAuth WebView -->
        <web:WebView2 x:Name="AuthWeb" Visibility="Collapsed" />
    </Grid>
</UserControl>
