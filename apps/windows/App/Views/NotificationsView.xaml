<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="YoruMimizuku.App.Views.NotificationsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:interop="using:YoruMimizuku.App.Interop">

    <Grid>
        <ListView x:Name="List" ItemsSource="{x:Bind Vm.Items, Mode=OneWay}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="interop:NotificationGroupDto">
                    <Grid Padding="4,8" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <PersonPicture Grid.Column="0" Width="32" Height="32"
                                       Tag="{x:Bind}" Tapped="OnActorAvatarTapped" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Bind Reason}" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind SubjectText}" Opacity="0.7" TextWrapping="Wrap"
                                       MaxLines="2" />
                            <TextBlock Text="{x:Bind Text}" Opacity="0.7" TextWrapping="Wrap" MaxLines="3" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <ProgressRing IsActive="{x:Bind Vm.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</UserControl>
