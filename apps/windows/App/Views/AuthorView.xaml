<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="YoruMimizuku.App.Views.AuthorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{ThemeResource AppHairlineBrush}" BorderThickness="0,0,0,1"
                Padding="16,18,16,12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <PersonPicture x:Name="Avatar" Grid.Column="0" Width="56" Height="56" />
                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock x:Name="DisplayNameText" FontSize="18" FontWeight="SemiBold"
                               Foreground="{ThemeResource AppTextBrush}" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="HandleText" Foreground="{ThemeResource AppTertiaryTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="BioText" Foreground="{ThemeResource AppTertiaryTextBrush}"
                               TextWrapping="Wrap" Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="FeedHost" Grid.Row="1" />
    </Grid>
</UserControl>
