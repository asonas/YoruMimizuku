<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="YoruMimizuku.App.Views.FeedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:YoruMimizuku.App.ViewModels">

    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left" Background="Transparent">
            <AppBarButton Icon="Refresh" Label="更新" Click="OnRefreshClick" />
            <AppBarButton Icon="Add" Label="投稿" Click="OnComposeClick" />
        </CommandBar>

        <ListView x:Name="PostsList"
                  Grid.Row="1"
                  ItemsSource="{x:Bind Vm.Posts, Mode=OneWay}"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="OnPostClick"
                  ContainerContentChanging="OnContainerContentChanging">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PostItem">
                    <Border BorderBrush="{ThemeResource AppHairlineBrush}"
                            BorderThickness="{x:Bind RowBorderThickness, Mode=OneWay}" Padding="16,11">
                        <StackPanel Spacing="3">
                            <!-- Repost / context header -->
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="53,0,0,0"
                                        Visibility="{x:Bind ContextVisibility}">
                                <FontIcon Glyph="&#xE8EE;" FontSize="11" Foreground="{ThemeResource AppTertiaryTextBrush}" />
                                <TextBlock Text="{x:Bind ContextLabel}" FontSize="12" Foreground="{ThemeResource AppTertiaryTextBrush}" />
                            </StackPanel>
                            <!-- Reply marker -->
                            <Button Margin="53,0,0,0" Background="Transparent" BorderThickness="0"
                                    Padding="0" HorizontalAlignment="Left" Visibility="{x:Bind ReplyVisibility, Mode=OneWay}"
                                    Tag="{x:Bind}" Click="OnReplyMarkerClick">
                                <TextBlock Text="{x:Bind ReplyMarkerText}" FontSize="12"
                                           Foreground="{ThemeResource AppAccentBrush}" />
                            </Button>

                            <Grid ColumnSpacing="11">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="42" VerticalAlignment="Stretch">
                                    <!-- Web-style thread connector dropping to the grouped reply below -->
                                    <Rectangle Width="2" Fill="{ThemeResource AppHairlineBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                               Margin="0,42,0,0"
                                               Visibility="{x:Bind ConnectorBottomVisibility, Mode=OneWay}" />
                                    <PersonPicture Width="42" Height="42" VerticalAlignment="Top"
                                                   ProfilePicture="{x:Bind Avatar}" Tag="{x:Bind}"
                                                   Tapped="OnAvatarTapped" />
                                </Grid>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                Tag="{x:Bind}" Click="OnAuthorClick">
                                            <TextBlock Text="{x:Bind AuthorDisplayName}" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource AppTextBrush}" />
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                Tag="{x:Bind}" Click="OnAuthorClick">
                                            <TextBlock Text="{x:Bind AuthorHandleAt}" FontSize="12"
                                                       Foreground="{ThemeResource AppTertiaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Button>
                                        <TextBlock Text="{x:Bind RelativeTime}" FontSize="12"
                                                   Foreground="{ThemeResource AppTertiaryTextBrush}"
                                                   FontFamily="Consolas" />
                                    </StackPanel>

                                    <!-- Rich body (facets) populated in OnContainerContentChanging -->
                                    <RichTextBlock x:Name="BodyRich" Foreground="{ThemeResource AppTextBrush}"
                                                   IsTextSelectionEnabled="True" />

                                    <!-- Media (image grid + video poster) with a tap-to-reveal
                                         sensitive-content curtain, populated in OnContainerContentChanging -->
                                    <Grid x:Name="MediaHost" Margin="0,3,0,0" HorizontalAlignment="Left" MaxWidth="440">
                                        <StackPanel Spacing="5">
                                            <Grid x:Name="ImagesHost" Visibility="{x:Bind ImagesVisibility}"
                                                  ColumnSpacing="5" RowSpacing="5" HorizontalAlignment="Left" />
                                            <Border x:Name="VideoHost" Visibility="Collapsed" HorizontalAlignment="Left" />
                                        </StackPanel>
                                        <Border x:Name="MediaCurtain" Visibility="Collapsed" CornerRadius="10"
                                                Background="#E61A1A1A" Tapped="OnMediaCurtainTapped" />
                                    </Grid>

                                    <!-- External link preview card populated in OnContainerContentChanging -->
                                    <Border x:Name="LinkCardHost" Margin="0,3,0,0" Visibility="Collapsed"
                                            HorizontalAlignment="Left" />

                                    <!-- Quote post (record embed) card populated in OnContainerContentChanging -->
                                    <Border x:Name="QuoteHost" Margin="0,3,0,0" Visibility="Collapsed"
                                            HorizontalAlignment="Left" />

                                    <!-- Action bar -->
                                    <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,3,0,0">
                                        <Button Click="OnReplyClick" Tag="{x:Bind}" Background="Transparent"
                                                ToolTipService.ToolTip="返信"
                                                BorderThickness="0" Padding="2">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="&#xE8BD;" FontSize="13" Foreground="{ThemeResource AppTertiaryTextBrush}" />
                                                <TextBlock Text="{x:Bind ReplyCount}" Foreground="{ThemeResource AppTertiaryTextBrush}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Background="Transparent" BorderThickness="0" Padding="2">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="{x:Bind RepostGlyph, Mode=OneWay}" FontSize="13" Foreground="{x:Bind RepostBrush, Mode=OneWay}" />
                                                <TextBlock Text="{x:Bind RepostCount, Mode=OneWay}" Foreground="{ThemeResource AppTertiaryTextBrush}" />
                                            </StackPanel>
                                            <Button.Flyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="{x:Bind RepostActionText, Mode=OneWay}" Click="OnRepostMenuClick" Tag="{x:Bind}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE8EE;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="引用" Click="OnQuoteMenuClick" Tag="{x:Bind}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE90A;" />
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                        <Button Click="OnLikeClick" Tag="{x:Bind}" Background="Transparent"
                                                BorderThickness="0" Padding="2">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <FontIcon Glyph="{x:Bind LikeGlyph, Mode=OneWay}" FontSize="13" Foreground="{x:Bind LikeBrush, Mode=OneWay}" />
                                                <TextBlock Text="{x:Bind LikeCount, Mode=OneWay}" Foreground="{ThemeResource AppTertiaryTextBrush}" />
                                            </StackPanel>
                                        </Button>
                                        <Button Click="OnCopyLinkClick" Tag="{x:Bind}" Background="Transparent"
                                                ToolTipService.ToolTip="リンクをコピー"
                                                BorderThickness="0" Padding="2">
                                            <FontIcon Glyph="&#xE71B;" FontSize="13" Foreground="{ThemeResource AppTertiaryTextBrush}" />
                                        </Button>
                                        <Button x:Name="DeleteButton" Click="OnDeleteClick" Tag="{x:Bind}" Background="Transparent"
                                                ToolTipService.ToolTip="削除" Visibility="Collapsed"
                                                BorderThickness="0" Padding="2">
                                            <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="{ThemeResource AppTertiaryTextBrush}" />
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ProgressRing Grid.Row="1" IsActive="{x:Bind Vm.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- Classified failed-state (offline / rate-limited / server / unknown) with retry -->
        <StackPanel Grid.Row="1" Visibility="{x:Bind Vm.ErrorVisibility, Mode=OneWay}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Spacing="8" MaxWidth="360" Margin="24">
            <TextBlock Text="{x:Bind Vm.FailureTitle, Mode=OneWay}" FontWeight="SemiBold" FontSize="16"
                       HorizontalAlignment="Center" Foreground="{ThemeResource AppTextBrush}" />
            <TextBlock Text="{x:Bind Vm.FailureMessage, Mode=OneWay}" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       Foreground="{ThemeResource AppTertiaryTextBrush}" />
            <Button Content="再試行" Click="OnRetryClick" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Image lightbox overlay -->
        <Grid x:Name="Lightbox" Grid.RowSpan="2" Background="#E6000000" Visibility="Collapsed"
              Tapped="OnLightboxTapped" IsTabStop="True">
            <Image x:Name="LightboxImage" Stretch="Uniform" Margin="40" />
            <Button x:Name="LightboxPrev" Content="&#xE76B;" FontFamily="Segoe MDL2 Assets"
                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"
                    Click="OnLightboxPrev" />
            <Button x:Name="LightboxNext" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,16,16,0"
                    Click="OnLightboxNext" />
            <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0"
                    Click="OnLightboxClose" />
        </Grid>
    </Grid>
</UserControl>
