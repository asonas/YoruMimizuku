<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="YoruMimizuku.App.Views.FeedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:YoruMimizuku.App.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="Refresh" Label="更新" Click="OnRefreshClick" />
            <AppBarButton Icon="Add" Label="投稿" Click="OnComposeClick" />
        </CommandBar>

        <ListView x:Name="PostsList"
                  Grid.Row="1"
                  ItemsSource="{x:Bind Vm.Posts, Mode=OneWay}"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="OnPostClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PostItem">
                    <Grid Padding="4,8" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <PersonPicture Grid.Column="0" Width="40" Height="40"
                                       ProfilePicture="{x:Bind AvatarUrl}" />

                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Bind ContextLabel}" Opacity="0.6" FontSize="12"
                                       Visibility="{x:Bind IsReply}" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{x:Bind AuthorDisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind AuthorHandle}" Opacity="0.6" />
                                <TextBlock Text="{x:Bind CreatedAt}" Opacity="0.5" FontSize="12" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind Body}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,4,0,0">
                                <TextBlock Text="{x:Bind ReplyCount}" Opacity="0.7" />
                                <Button Background="Transparent" BorderThickness="0" Padding="2"
                                        Click="OnRepostClick" Tag="{x:Bind}">
                                    <TextBlock Text="{x:Bind RepostCount, Mode=OneWay}" />
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="2"
                                        Click="OnLikeClick" Tag="{x:Bind}">
                                    <TextBlock Text="{x:Bind LikeCount, Mode=OneWay}" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ProgressRing Grid.Row="1" x:Name="Spinner" IsActive="{x:Bind Vm.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</UserControl>
