<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="YoruMimizuku.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="20" MaxWidth="520" HorizontalAlignment="Left">
            <TextBlock Text="設定" FontSize="24" FontWeight="SemiBold" />

            <StackPanel Spacing="6">
                <TextBlock Text="表示密度" FontWeight="SemiBold" />
                <RadioButtons x:Name="DensityChoice" SelectionChanged="OnDensityChanged">
                    <x:String>コンパクト</x:String>
                    <x:String>ゆとり</x:String>
                </RadioButtons>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="配色 (randoma11y)" FontWeight="SemiBold" />
                <TextBox x:Name="ThemeUrlBox" PlaceholderText="https://randoma11y.com/?... のURLを貼り付け" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="適用" Click="OnApplyThemeClick" />
                    <Button Content="デフォルトに戻す" Click="OnResetThemeClick" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="フォントサイズ" FontWeight="SemiBold" />
                <Slider x:Name="FontSlider" Minimum="11" Maximum="24" Value="14"
                        ValueChanged="OnFontSizeChanged" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="通知" FontWeight="SemiBold" />
                <TextBlock Text="更新間隔" Opacity="0.7" />
                <ComboBox x:Name="PollIntervalBox" SelectionChanged="OnPollIntervalChanged" HorizontalAlignment="Left">
                    <ComboBoxItem Content="15秒" />
                    <ComboBoxItem Content="30秒" />
                    <ComboBoxItem Content="1分" />
                    <ComboBoxItem Content="5分" />
                </ComboBox>
                <CheckBox x:Name="BadgeCheck" Content="未読バッジを表示"
                          Checked="OnBadgeChanged" Unchecked="OnBadgeChanged" />
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="アップデート" FontWeight="SemiBold" />
                <TextBlock x:Name="VersionText" Opacity="0.7" />
                <CheckBox x:Name="AutoUpdateCheck" Content="起動時に自動で確認"
                          Checked="OnAutoUpdateChanged" Unchecked="OnAutoUpdateChanged" />
                <ComboBox x:Name="UpdateChannelBox" SelectionChanged="OnUpdateChannelChanged"
                          HorizontalAlignment="Left">
                    <ComboBoxItem Content="リリース" />
                    <ComboBoxItem Content="開発版" />
                </ComboBox>
                <Button Content="今すぐ確認" Click="OnCheckUpdatesClick" HorizontalAlignment="Left" />
                <TextBlock x:Name="UpdateStatusText" Opacity="0.7" TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
