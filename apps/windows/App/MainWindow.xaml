<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="YoruMimizuku.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Grid x:Name="RootGrid">
        <!-- Login gate; swapped for the main shell after authentication. -->
        <ContentControl x:Name="LoginHost" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />

        <Grid x:Name="ShellRoot" Visibility="Collapsed">
            <muxc:NavigationView
                x:Name="Nav"
                PaneDisplayMode="LeftCompact"
                IsBackButtonVisible="Collapsed"
                IsSettingsVisible="True"
                SelectionChanged="OnNavSelectionChanged">
                <muxc:NavigationView.MenuItems>
                    <!-- Tab items are generated in code-behind from WorkspaceViewModel.Tabs. -->
                </muxc:NavigationView.MenuItems>
                <ContentControl x:Name="ContentHost"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch" />
            </muxc:NavigationView>
        </Grid>
    </Grid>
</Window>
